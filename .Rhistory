library(grid)
M <- matrix(c(
NA, .9, .7, .2, .1,
NA, NA, .8, .3, .2,
NA, NA, NA, .6, .4,
NA, NA, NA, NA, .9,
NA, NA, NA, NA, NA
), nrow = 5, byrow = TRUE)
cols <- grey.colors(20)
breaks <- seq(0, 1, length.out = length(cols) + 1)
col_matrix <- cut(
1 - M,
breaks = breaks,
labels = cols,
include.lowest = TRUE
)
make_rects <- function(mat, rotate = FALSE) {
make_rects <- function(mat, rotate = FALSE) {
nr <- nrow(mat)
nc <- ncol(mat)
xx <- rep((1:nc) / nc, nr)
yy <- rep((1:nr) / nr, each = nc)
grob <- rectGrob(
x = xx, y = yy,
width = 1 / nc,
height = 1 / nr,
just = c("right", "top"),
gp = gpar(col = "white", fill = as.vector(t(col_matrix)))
)
if (rotate) {
grob <- editGrob(
grob,
vp = viewport(width = .8, height = .8, angle = -45)
)
}
grob
}
grid.newpage()
make_rects <- function(mat, rotate = FALSE) {
nr <- nrow(mat)
nc <- ncol(mat)
xx <- rep((1:nc) / nc, nr)
yy <- rep((1:nr) / nr, each = nc)
grob <- rectGrob(
x = xx, y = yy,
width = 1 / nc,
height = 1 / nr,
just = c("right", "top"),
gp = gpar(col = "white", fill = as.vector(t(col_matrix)))
)
if (rotate) {
grob <- editGrob(
grob,
vp = viewport(width = .8, height = .8, angle = -45)
)
}
grob
}
grid.newpage()
grid.draw(make_rects(M, rotate = TRUE))
