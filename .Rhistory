)
cols <- heat.colors(10)
breaks <- seq(0, 1, length.out = 11)
cell_cols <- cols[cut(M, breaks, labels = FALSE, include.lowest = TRUE)]
grid.newpage()
pushViewport(
viewport(
x = 0.5,
y = 0.55,
width = 0.6,
height = 0.6,
angle = -45
)
)
nr <- nrow(M)
nc <- ncol(M)
for (i in seq_len(nr)) {
for (j in seq_len(nc)) {
if (!is.na(M[i, j])) {
grid.rect(
x = (j - 0.5) / nc,
y = 1 - (i - 0.5) / nr,
width = 1 / nc,
height = 1 / nr,
gp = gpar(
fill = cell_cols[i, j],
col = "white"
)
)
}
}
}
