library(matchTag)
library(readxl)
library(dplyr)
library(dartR.base)
library(stringr)
setwd("~/projects/Set3")
# Read MTAs
df <- read_excel("./14.sequence.tags.2272.MTAs_M.and.X.xlsx", sheet = "in") %>%
mutate(marker.name = paste0(subset,"_", variable, "_", marker.name))
# Read gl SNPs
gl <- readRDS("./co-analysis-v3_pops_PvDHRT.RDS")
mgl <- gl.keep.pop(gl, "Mesoamerican", recalc = T)
dartSet <- DArTSet$new(dataset = mgl)
# Read sil
sil_gl <- readRDS("./BGdd2025003_SilicoDARTs_bean.panel.RDS")
sil_mgl <- gl.keep.pop(sil_gl, "Mesoamerican", recalc = T)
sil_dartSet <- DArTSet$new(dataset = sil_mgl, dataset_type = "SIL")
SNPs <- df %>%
dplyr::filter(marker == "SNP") %>%
mutate(alleles = str_split(marker.name, "-", simplify = T)[,3],
favorable.geno = as.integer(favorable.geno),
idx_a = if_else( favorable.geno == 1, NA, (favorable.geno/2)+1))
allele_mat <- str_split(SNPs$alleles, "\\/", simplify = TRUE)
SNPs <- SNPs %>%
mutate(
fallele = if_else(
is.na(idx_a),
NA_character_,
allele_mat[cbind(row_number(), as.integer(idx_a))]
)
) %>%
dplyr::select(marker.name, AlleleSequence_REF, fallele) %>%
rename(AlleleID = marker.name,
AlleleSequence = AlleleSequence_REF,
Favorable.allele = fallele) %>%
distinct() %>%
dplyr::filter(!is.na(Favorable.allele))
meso_freqs <- purrr::pmap(SNPs,
function(AlleleID, AlleleSequence, Favorable.allele) {
if (is.na(AlleleID) || is.na(AlleleSequence) || is.na(Favorable.allele)) {
stop("Some NA")
}
mta <- MTA$new(AlleleID, AlleleSequence, Favorable.allele)
tryCatch({
homologs <- dartSet$find_homolog(mta)
freq <- c()
if (length(homologs) > 0 && !is.na(homologs)) {
ids <- names(homologs)
for (iidx in ids) {
freq <- c(freq, dartSet$get_favourable_freq(iidx,
mta$favorableAllele))
}
}
freq
}, error = function(e){
message("Something wrong:", e$message)
NA
})
})
names(meso_freqs) <- SNPs$AlleleID
meso_freq_snps_df <- purrr::imap_dfr(meso_freqs, function(x, qry_id) {
if (is.na(x) || is.null(x) || length(x) == 0) {
data.frame(
loc_id = qry_id,
f_allele = NA_character_,
afreq = NA_real_
)
} else {
data.frame(
loc_id = qry_id,
f_allele = names(x),
afreq = as.numeric(x)
)
}
})
SILs <- df %>%
dplyr::filter(marker == "SilicoDArT") %>%
mutate(favorable.geno = as.numeric(favorable.geno)) %>%
rename(AlleleID = marker.name,
AlleleSequence = AlleleSequence_SilicoDArT,
Favorable.allele = favorable.geno) %>%
dplyr::select(AlleleID, AlleleSequence, Favorable.allele) %>%
distinct() %>%
filter(!is.na(Favorable.allele))
sil_meso_freqs <- purrr::pmap(SILs,
function(AlleleID, AlleleSequence, Favorable.allele) {
if (is.na(AlleleID) || is.na(AlleleSequence) || is.na(Favorable.allele)) {
stop("Some NA")
}
mta <- MTA$new(AlleleID, AlleleSequence, as.character(Favorable.allele))
homologs <- sil_dartSet$find_homolog(mta,cutoff = 0)
freq <- c()
if (length(homologs) > 0 && !is.na(homologs)) {
ids <- names(homologs)
for (iidx in ids) {
freq <- c(freq, sil_dartSet$get_favourable_freq(iidx,
mta$favorableAllele))
}
}
freq
})
names(sil_meso_freqs) <- SILs$AlleleID
meso_freq_sils_df <- purrr::imap_dfr(sil_meso_freqs, function(x, qry_id) {
if (is.null(x) || length(x) == 0) {
data.frame(
loc_id = qry_id,
f_allele = NA_character_,
afreq = NA_real_
)
} else {
data.frame(
loc_id = qry_id,
f_allele = names(x),
afreq = as.numeric(x)
)
}
})
meso_freq <- rbind(meso_freq_snps_df, meso_freq_sils_df) %>%
mutate(row = str_split_i(loc_id,"_",1))
out <- df %>%
merge(meso_freq, by.x = "marker.name", by.y = "loc_id")
